# Environment variables
.env

# ROM files — never commit, regardless of extension or location.
# `roms/` is the conventional dump directory; `*.zip` covers archived ROMs
# (a `git add -A` would otherwise pick them up since they don't match *.gb).
*.gb
*.gbc
*.gba
*.ram
*.state
*.zip
roms/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Logs
logs/
*.log
buttons.txt

# Virtual environments
venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# System
.DS_Store

# Agent runtime state — per-run, do not commit
knowledge_base.json
saves/
thoughts.log               # redundant with *.log above; kept for clarity

# Atomic-write tempfiles and editor backup files
*.tmp
*.bak

# Claude Code worktrees and per-machine local settings
.claude/worktrees/
.claude/settings.local.json

# Python venvs and tool caches
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Personal notes / per-machine docs — anything matching *.local.md stays local
*.local.md